#!/bin/sh

echo "🚀 Pre-push checks..."
echo ""

# 1. Quality + Build
echo "📋 Running quality checks..."
npm run quality || {
  echo ""
  echo "❌ Quality checks failed! Fix issues before pushing."
  exit 1
}
echo "✅ Quality checks passed"
echo ""

echo "🔨 Building..."
npm run build || {
  echo ""
  echo "❌ Build failed! Fix issues before pushing."
  exit 1
}
echo "✅ Build passed"
echo ""

# 2. Changeset check on feature branches (BLOCKING)
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if echo "$CURRENT_BRANCH" | grep -qE "^feature/"; then
  CHANGESETS=$(git diff --name-only origin/develop...HEAD -- '.changeset/*.md' 2>/dev/null | grep -v 'README.md' || true)
  if [ -z "$CHANGESETS" ]; then
    echo "❌ No changeset found in this branch. Push blocked."
    echo ""
    echo "   Run 'npx changeset' to add one."
    echo "   If no version bump is needed: 'npx changeset --empty'"
    echo ""
    exit 1
  else
    echo "✅ Changeset found"
    echo ""
  fi
fi

echo "✅ All pre-push checks passed"
