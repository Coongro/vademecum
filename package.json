{
  "name": "@coongro/vademecum",
  "version": "0.1.2",
  "type": "module",
  "description": "Catálogo regulatorio reutilizable (librería): contrato de providers, registry, sync + caché del padrón, y UI de búsqueda/autofill. Agnóstico de fuente; los providers (SENASA, etc.) se enchufan.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "assets",
    "drizzle",
    "coongro.manifest.json"
  ],
  "scripts": {
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "quality": "npm run typecheck && npm run format:check && npm run lint",
    "quality:fix": "npm run format && npm run lint:fix",
    "sync-version": "node scripts/sync-version.cjs",
    "version": "npm run sync-version && git add coongro.manifest.json",
    "prepublishOnly": "npm run quality && npm run build",
    "build": "npm run build:css && npm run copy:fontawesome && tsc",
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./src/styles/tailwind.css -o ./dist/assets/tailwind.css --minify",
    "copy:fontawesome": "node scripts/copy-fontawesome.cjs",
    "dev": "npm run build:css && tsc --watch"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@coongro/plugin-sdk": ">=0.53.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@coongro/plugin-sdk": ">=0.53.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-sonarjs": "^0.24.0",
    "husky": "^9.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.0",
    "drizzle-orm": "^0.38.3",
    "tailwindcss": "^3.4.0",
    "@fortawesome/fontawesome-free": "^6.5.0"
  }
}
